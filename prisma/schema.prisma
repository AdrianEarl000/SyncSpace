// SyncSpace — Prisma Schema
// Database: Supabase (PostgreSQL)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Auth Models (NextAuth) ───────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?   // null for OAuth users
  color         String    @default("#6366F1") // cursor/avatar color
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts          Account[]
  sessions          Session[]
  workspaceMembers  WorkspaceMember[]
  messages          Message[]
  activities        Activity[]
  whiteboardStrokes WhiteboardStroke[]
  sentInvites       WorkspaceInvite[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Core Models ─────────────────────────────────────────────────────────────

model Workspace {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  icon        String?  // emoji icon
  color       String   @default("#6366F1")
  isPublic    Boolean  @default(false)
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members            WorkspaceMember[]
  messages           Message[]
  activities         Activity[]
  whiteboardSessions WhiteboardSession[]
  invites            WorkspaceInvite[]

  @@map("workspaces")
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  role        Role     @default(MEMBER)
  joinedAt    DateTime @default(now())
  lastSeenAt  DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@map("workspace_members")
}

model WorkspaceInvite {
  id          String       @id @default(cuid())
  workspaceId String
  invitedBy   String
  email       String
  token       String       @unique @default(cuid())
  status      InviteStatus @default(PENDING)
  expiresAt   DateTime
  createdAt   DateTime     @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  inviter   User      @relation(fields: [invitedBy], references: [id], onDelete: Cascade)

  @@map("workspace_invites")
}

model Message {
  id          String    @id @default(cuid())
  content     String    @db.Text
  workspaceId String
  userId      String
  replyToId   String?
  editedAt    DateTime?
  deleted     Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  replyTo   Message?  @relation("MessageReplies", fields: [replyToId], references: [id])
  replies   Message[] @relation("MessageReplies")

  @@index([workspaceId, createdAt])
  @@map("messages")
}

model WhiteboardSession {
  id          String   @id @default(cuid())
  workspaceId String
  name        String   @default("Untitled Board")
  thumbnail   String?  // base64 or URL snapshot
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  strokes   WhiteboardStroke[]

  @@map("whiteboard_sessions")
}

model WhiteboardStroke {
  id        String   @id @default(cuid())
  sessionId String
  userId    String
  data      Json     // { points: [{x,y}], color, width, tool }
  createdAt DateTime @default(now())

  session WhiteboardSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("whiteboard_strokes")
}

model Activity {
  id          String       @id @default(cuid())
  workspaceId String
  userId      String
  type        ActivityType
  metadata    Json?        // flexible extra data per activity type
  createdAt   DateTime     @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt(sort: Desc)])
  @@map("activities")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  OWNER
  ADMIN
  MEMBER
  GUEST
}

enum InviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

enum ActivityType {
  USER_JOINED
  USER_LEFT
  MESSAGE_SENT
  WHITEBOARD_EDITED
  WHITEBOARD_CLEARED
  WORKSPACE_CREATED
  WORKSPACE_UPDATED
  MEMBER_INVITED
  MEMBER_REMOVED
  TASK_CREATED
  TASK_COMPLETED
  FILE_UPLOADED
}
